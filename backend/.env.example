# Supabase PostgreSQL connection string
# Found in: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction" pooler (port 6543) for serverless, or "Direct" connection (port 5432) for persistent servers
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase project credentials
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Secret key for signing JWTs (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server port
PORT=5000

# Environment: development | production | test
NODE_ENV=development

# (Optional) Allowed frontend origin for CORS
CLIENT_ORIGIN=http://localhost:3000
